{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "otlp receiver configuration",
  "type": "object",
  "properties": {
    "grpc": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "authenticator": {
              "type": "string"
            }
          }
        },
        "include_metadata": {
          "type": "boolean"
        },
        "keepalive": {
          "type": "object",
          "properties": {
            "enforcement_policy": {
              "type": "object",
              "properties": {
                "min_time": {
                  "type": "string",
                  "format": "duration"
                },
                "permit_without_stream": {
                  "type": "boolean"
                }
              }
            },
            "server_parameters": {
              "type": "object",
              "properties": {
                "max_connection_age": {
                  "type": "string",
                  "format": "duration"
                },
                "max_connection_age_grace": {
                  "type": "string",
                  "format": "duration"
                },
                "max_connection_idle": {
                  "type": "string",
                  "format": "duration"
                },
                "time": {
                  "type": "string",
                  "format": "duration"
                },
                "timeout": {
                  "type": "string",
                  "format": "duration"
                }
              }
            }
          }
        },
        "max_concurrent_streams": {
          "type": "integer"
        },
        "max_recv_msg_size_mib": {
          "type": "integer"
        },
        "middlewares": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          }
        },
        "netaddr": {
          "type": "object",
          "properties": {
            "dialer": {
              "type": "object",
              "properties": {
                "timeout": {
                  "type": "string",
                  "format": "duration"
                }
              }
            },
            "endpoint": {
              "type": "string"
            },
            "transport": {
              "type": "string"
            }
          }
        },
        "read_buffer_size": {
          "type": "integer"
        },
        "tls": {
          "type": "object",
          "properties": {
            "client_ca_file": {
              "type": "string"
            },
            "client_ca_file_reload": {
              "type": "boolean"
            },
            "config": {
              "type": "object",
              "properties": {
                "ca_file": {
                  "type": "string"
                },
                "ca_pem": {
                  "type": "string"
                },
                "cert_file": {
                  "type": "string"
                },
                "cert_pem": {
                  "type": "string"
                },
                "cipher_suites": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "curve_preferences": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "include_system_ca_certs_pool": {
                  "type": "boolean"
                },
                "key_file": {
                  "type": "string"
                },
                "key_pem": {
                  "type": "string"
                },
                "max_version": {
                  "type": "string"
                },
                "min_version": {
                  "type": "string"
                },
                "reload_interval": {
                  "type": "string",
                  "format": "duration"
                },
                "tpm": {
                  "type": "object",
                  "properties": {
                    "auth": {
                      "type": "string"
                    },
                    "enabled": {
                      "type": "boolean"
                    },
                    "owner_auth": {
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "enabled",
                    "path",
                    "owner_auth",
                    "auth"
                  ]
                }
              }
            }
          }
        },
        "write_buffer_size": {
          "type": "integer"
        }
      },
      "required": [
        "netaddr"
      ]
    },
    "http": {
      "type": "object",
      "properties": {
        "logs_url_path": {
          "description": "The URL path to receive logs on. If omitted \"/v1/logs\" will be used.",
          "type": "string"
        },
        "metrics_url_path": {
          "description": "The URL path to receive metrics on. If omitted \"/v1/metrics\" will be used.",
          "type": "string"
        },
        "serverconfig": {
          "type": "object",
          "properties": {
            "auth": {
              "type": "object",
              "properties": {
                "config": {
                  "type": "object",
                  "properties": {
                    "authenticator": {
                      "type": "string"
                    }
                  }
                },
                "request_params": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "compression_algorithms": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cors": {
              "type": "object",
              "properties": {
                "allowed_headers": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "allowed_origins": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "max_age": {
                  "type": "integer"
                }
              }
            },
            "endpoint": {
              "type": "string"
            },
            "idle_timeout": {
              "type": "string",
              "format": "duration"
            },
            "include_metadata": {
              "type": "boolean"
            },
            "keep_alives_enabled": {
              "type": "boolean"
            },
            "max_request_body_size": {
              "type": "integer"
            },
            "middlewares": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  }
                }
              }
            },
            "read_header_timeout": {
              "type": "string",
              "format": "duration"
            },
            "read_timeout": {
              "type": "string",
              "format": "duration"
            },
            "response_headers": {
              "type": "object"
            },
            "tls": {
              "type": "object",
              "properties": {
                "client_ca_file": {
                  "type": "string"
                },
                "client_ca_file_reload": {
                  "type": "boolean"
                },
                "config": {
                  "type": "object",
                  "properties": {
                    "ca_file": {
                      "type": "string"
                    },
                    "ca_pem": {
                      "type": "string"
                    },
                    "cert_file": {
                      "type": "string"
                    },
                    "cert_pem": {
                      "type": "string"
                    },
                    "cipher_suites": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "curve_preferences": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "include_system_ca_certs_pool": {
                      "type": "boolean"
                    },
                    "key_file": {
                      "type": "string"
                    },
                    "key_pem": {
                      "type": "string"
                    },
                    "max_version": {
                      "type": "string"
                    },
                    "min_version": {
                      "type": "string"
                    },
                    "reload_interval": {
                      "type": "string",
                      "format": "duration"
                    },
                    "tpm": {
                      "type": "object",
                      "properties": {
                        "auth": {
                          "type": "string"
                        },
                        "enabled": {
                          "type": "boolean"
                        },
                        "owner_auth": {
                          "type": "string"
                        },
                        "path": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "enabled",
                        "path",
                        "owner_auth",
                        "auth"
                      ]
                    }
                  }
                }
              }
            },
            "write_timeout": {
              "type": "string",
              "format": "duration"
            }
          },
          "required": [
            "read_header_timeout",
            "write_timeout",
            "idle_timeout"
          ]
        },
        "traces_url_path": {
          "description": "The URL path to receive traces on. If omitted \"/v1/traces\" will be used.",
          "type": "string"
        }
      },
      "required": [
        "serverconfig"
      ]
    }
  }
}
