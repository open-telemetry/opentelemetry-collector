                expectNewMetric:    true,
                {{- if $targetLegacyAttrs }}
                expectLegacyAttrs:  true,
                {{- end }}
            },
            {{- else }}
            {
                name:               "dual_emission",
                disableOld:         false,
                enableNew:          true,
                expectLegacyMetric: true,
                expectNewMetric:    true,
            },
            {{- end }}

            {
                name:               "new_only",
                disableOld:         true,
                enableNew:          true,
                expectLegacyMetric: false,
                expectNewMetric:    true,
                {{- if $targetLegacyAttrs }}
                expectLegacyAttrs:  false,
                {{- end }}
