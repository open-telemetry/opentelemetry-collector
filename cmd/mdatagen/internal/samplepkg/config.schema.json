{
  "$id": "go.opentelemetry.io/collector/cmd/mdatagen/internal/samplepkg",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "port_number": {
      "type": "integer",
      "description": "A port number to connect to.",
      "minimum": 1,
      "maximum": 65535
    },
    "sample_config": {
      "type": "object",
      "properties": {
        "host_name": {
          "type": "string",
          "description": "The host name to connect to.",
          "default": "localhost",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "description": "The port to connect to.",
          "default": 8080,
          "minimum": 1,
          "maximum": 10000
        }
      },
      "required": [
        "host_name"
      ]
    }
  },
  "title": "pkg/samplepkg"
}